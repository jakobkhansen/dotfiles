{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "pwd": "osc99",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#77E4F7",
          "options": {
            "style": "agnoster_short",
            "max_depth": 5
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#43D426",
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
